{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MMD",
  "version": "0.1.0",
  "identifier": "com.example.mmd",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "MMD",
        "width": 1460,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true,
        "decorations": false,
        "transparent": false
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
